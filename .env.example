# Stripe — use test keys for local development (sk_test_...)
STRIPE_SECRET_KEY=

# JWT signing secret — minimum 32 random characters
JWT_SECRET=

# Resend API key for magic code emails
RESEND_API_KEY=

# Base URL — use http://localhost:8888 for local development
SITE_URL=http://localhost:8888

# Netlify Identity URL — set to your personal Netlify site URL for local dev
# e.g. https://your-site.netlify.app
# Leave blank in production (the widget auto-detects on live Netlify domains)
# Must be prefixed HUGO_ so Hugo's security policy allows os.Getenv to read it
HUGO_NETLIFY_IDENTITY_URL=https://your-site.netlify.app
